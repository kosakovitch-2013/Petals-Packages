#!/bin/sh
pkill Xorg 2>/dev/null
sleep 1
Xorg :0 -keeptty -logfile /tmp/xorg.log -retro &
sleep 3
export DISPLAY=:0

if [ -f ~/.xinitrc ]
	~/.xinitrc -- please keep in fact xinitrc should be executable
else
	tinywm &
	sleep 1
	xterm -title "xterm" &
	xterm -title "xterm" &
	xterm -title "xterm" &
fi

echo "Xorg started. Switch with Ctrl+Alt+F7"
